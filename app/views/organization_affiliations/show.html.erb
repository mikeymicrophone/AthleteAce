<% content_for :title, "#{@organization_affiliation.team.name} Organization Affiliation" %>

<div class="w-full space-y-8">
  <div class="rounded-3xl border border-orange-200 bg-linear-to-br from-orange-50 via-white to-amber-50 p-8 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Organization Affiliation</p>
    <h1 class="mt-2 text-4xl font-black tracking-tight text-gray-950"><%= @organization_affiliation.team.name %></h1>
    <p class="mt-3 text-lg text-gray-600">
      Part of
      <%= link_to @organization_affiliation.organization.name, organization_path(@organization_affiliation.organization), class: "font-semibold text-orange-700 hover:underline" %>
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-bold text-gray-950">Affiliation Details</h2>
      <dl class="mt-5 space-y-4">
        <div class="rounded-2xl bg-gray-50 p-4">
          <dt class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Organization</dt>
          <dd class="mt-2 text-lg font-semibold text-gray-950"><%= link_to @organization_affiliation.organization.name, @organization_affiliation.organization %></dd>
        </div>
        <div class="rounded-2xl bg-gray-50 p-4">
          <dt class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Team</dt>
          <dd class="mt-2 text-lg font-semibold text-gray-950"><%= link_to @organization_affiliation.team.name, @organization_affiliation.team %></dd>
        </div>
        <div class="rounded-2xl bg-gray-50 p-4">
          <dt class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Start Date</dt>
          <dd class="mt-2 text-lg font-semibold text-gray-950"><%= @organization_affiliation.start_date&.strftime("%B %d, %Y") || "Unknown" %></dd>
        </div>
        <div class="rounded-2xl bg-gray-50 p-4">
          <dt class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">End Date</dt>
          <dd class="mt-2 text-lg font-semibold text-gray-950"><%= @organization_affiliation.end_date&.strftime("%B %d, %Y") || "Present" %></dd>
        </div>
      </dl>
    </section>

    <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-bold text-gray-950">Context</h2>
      <dl class="mt-5 space-y-4">
        <% if @organization_affiliation.team.league.present? %>
          <div class="rounded-2xl bg-gray-50 p-4">
            <dt class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">League</dt>
            <dd class="mt-2 text-lg font-semibold text-gray-950"><%= link_to @organization_affiliation.team.league.name, @organization_affiliation.team.league %></dd>
          </div>
        <% end %>
        <% if @organization_affiliation.sport.present? %>
          <div class="rounded-2xl bg-gray-50 p-4">
            <dt class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Sport</dt>
            <dd class="mt-2 text-lg font-semibold text-gray-950"><%= link_to @organization_affiliation.sport.name, @organization_affiliation.sport %></dd>
          </div>
        <% end %>
        <% if @organization_affiliation.details.present? %>
          <div class="rounded-2xl bg-gray-50 p-4">
            <dt class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Details</dt>
            <dd class="mt-2 text-sm text-gray-700"><pre><%= JSON.pretty_generate(@organization_affiliation.details) %></pre></dd>
          </div>
        <% end %>
      </dl>
    </section>
  </div>
</div>
