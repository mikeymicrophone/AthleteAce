<% content_for :title, "Organizations" %>

<div class="w-full space-y-6">
  <div class="flex items-end justify-between gap-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Organization Layer</p>
      <h1 class="text-4xl font-extrabold text-gray-900">Organizations</h1>
    </div>
    <p class="text-sm text-gray-500"><%= pluralize(@organizations.size, "organization") %></p>
  </div>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    <% @organizations.each do |organization| %>
      <%= link_to organization_path(organization), class: "rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-orange-300 hover:shadow-md" do %>
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-2xl font-bold text-gray-950"><%= organization.name %></h2>
            <% if organization.abbreviation.present? %>
              <p class="mt-1 text-sm font-semibold uppercase tracking-[0.14em] text-gray-500"><%= organization.abbreviation %></p>
            <% end %>
          </div>
          <div class="text-sm text-gray-500"><%= pluralize(organization.current_teams.size, "current team") %></div>
        </div>

        <% if organization.description.present? %>
          <p class="mt-4 text-sm leading-6 text-gray-600"><%= truncate(organization.description, length: 180) %></p>
        <% end %>

        <div class="mt-5 border-t border-gray-100 pt-4">
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-gray-500">Current Teams</p>
          <% if organization.current_teams.any? %>
            <div class="flex flex-wrap gap-3">
              <% organization.current_teams.each do |team| %>
                <span class="inline-flex rounded-full bg-orange-50 px-3 py-1 text-sm font-medium text-orange-800">
                  <%= team.name %>
                </span>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">No current teams linked.</p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
