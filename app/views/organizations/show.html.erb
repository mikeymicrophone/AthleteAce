<% content_for :title, @organization.name %>

<div class="w-full space-y-8">
  <div class="rounded-3xl border border-orange-200 bg-linear-to-br from-orange-50 via-white to-amber-50 p-8 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">Organization</p>
    <h1 class="mt-2 text-5xl font-black tracking-tight text-gray-950"><%= @organization.name %></h1>
    <% if @organization.abbreviation.present? %>
      <p class="mt-3 text-lg font-medium text-gray-600"><%= @organization.abbreviation %></p>
    <% end %>
    <% if @organization.description.present? %>
      <p class="mt-4 max-w-3xl text-base leading-7 text-gray-600"><%= @organization.description %></p>
    <% end %>
    <% if @organization.url.present? %>
      <div class="mt-4">
        <%= link_to @organization.url, @organization.url, class: "text-sm font-semibold text-orange-700 hover:underline" %>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-8 xl:grid-cols-2">
    <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="mb-5 flex items-end justify-between gap-4 border-b border-gray-100 pb-4">
        <h2 class="text-2xl font-bold text-gray-950">Current Teams</h2>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500"><%= pluralize(@organization.current_teams.size, "team") %></p>
      </div>

      <% if @organization.current_teams.any? %>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <% @organization.current_teams.each do |team| %>
            <%= link_to team_path(team), class: "rounded-2xl border border-gray-200 bg-gray-50 px-4 py-4 transition hover:border-orange-300 hover:bg-white hover:shadow-md" do %>
              <%= display_name_with_lazy_logo(team, link: false) %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No current teams linked to this organization.</p>
      <% end %>
    </section>

    <section class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="mb-5 flex items-end justify-between gap-4 border-b border-gray-100 pb-4">
        <h2 class="text-2xl font-bold text-gray-950">Affiliation History</h2>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500"><%= pluralize(@organization.organization_affiliations.size, "affiliation") %></p>
      </div>

      <% if @organization.organization_affiliations.any? %>
        <div class="space-y-3">
          <% @organization.organization_affiliations.chronological.each do |affiliation| %>
            <%= link_to organization_affiliation_path(affiliation), class: "block rounded-2xl border border-gray-200 bg-gray-50 px-4 py-4 transition hover:border-orange-300 hover:bg-white hover:shadow-md" do %>
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-base font-semibold text-gray-950"><%= affiliation.team.name %></p>
                  <p class="mt-1 text-sm text-gray-500"><%= affiliation.team.league.name %></p>
                </div>
                <div class="text-right text-sm text-gray-600">
                  <p><%= affiliation.start_date&.strftime("%Y-%m-%d") || "Unknown start" %></p>
                  <p><%= affiliation.end_date&.strftime("%Y-%m-%d") || "Present" %></p>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No affiliations recorded for this organization.</p>
      <% end %>
    </section>
  </div>
</div>
